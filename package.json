{
  "name": "daily-three",
  "type": "module",
  "version": "0.1.0",
  "description": "Daily Three: Auto & Product Design — curated design news digest",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && astro dev",
    "build": "astro build && node scripts/copy-root-redirect.mjs",
    "preview": "astro preview",
    "digest": "tsx scripts/run-digest.ts",
    "digest:dry": "tsx scripts/run-digest.ts --dry-run",
    "images:re-enrich": "tsx scripts/re-enrich-images.ts",
    "media:re-enrich": "tsx scripts/re-enrich-media.ts",
    "test": "npm run test:image && npm run test:media && npm run test:dedup && npm run test:schedule",
    "test:schedule": "tsx --test scripts/digest-schedule.test.ts",
    "test:image": "tsx --test scripts/image-url.test.ts",
    "test:dedup": "tsx --test scripts/story-dedup.test.ts",
    "test:media": "tsx --test scripts/scrape-media.test.ts",
    "workflow:dispatch": "powershell -ExecutionPolicy Bypass -File scripts/trigger-workflow.ps1",
    "astro": "astro"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@astrojs/sitemap": "^3.7.3",
    "@supabase/supabase-js": "^2.49.8",
    "astro": "^6.3.7",
    "cheerio": "^1.2.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3"
  }
}
