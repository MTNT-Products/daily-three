{
  "name": "daily-three",
  "type": "module",
  "version": "0.1.0",
  "description": "Daily Three: Auto & Product Design — curated design news digest",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "digest": "tsx scripts/run-digest.ts",
    "digest:dry": "tsx scripts/run-digest.ts --dry-run",
    "images:re-enrich": "tsx scripts/re-enrich-images.ts",
    "media:re-enrich": "tsx scripts/re-enrich-media.ts",
    "workflow:dispatch": "powershell -ExecutionPolicy Bypass -File scripts/trigger-workflow.ps1",
    "astro": "astro"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@astrojs/sitemap": "^3.7.3",
    "@supabase/supabase-js": "^2.49.8",
    "astro": "^6.3.7",
    "cheerio": "^1.2.0",
    "resend": "^6.12.3",
    "rss-parser": "^3.13.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3"
  }
}
