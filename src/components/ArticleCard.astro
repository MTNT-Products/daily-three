---
interface Article {
  title: string;
  summary: string;
  source: string;
  sourceId: string;
  url: string;
  image?: string;
}

interface Props {
  article: Article;
  index: number;
  digestSlug: string;
}

const { article, index, digestSlug } = Astro.props;
const num = String(index + 1).padStart(2, '0');
const feedbackId = `${digestSlug}-${index}`;
---

<article class="article-card" data-article-url={article.url}>
  {
    article.image ? (
      <img class="article-img" src={article.image} alt="" loading="lazy" data-fallback />
    ) : (
      <div class="article-img placeholder">画像なし</div>
    )
  }
  <div class="article-body">
    <div class="article-num">{num}</div>
    <h2>{article.title}</h2>
    <p class="summary">{article.summary}</p>
    <p class="source-line">
      出典: <a href={article.url} target="_blank" rel="noopener noreferrer">{article.source}</a>
    </p>
    <div
      class="feedback"
      data-feedback-id={feedbackId}
      data-source-id={article.sourceId}
      data-url={article.url}
    >
      <button type="button" data-v="good">Good</button>
      <button type="button" data-v="bad">Bad</button>
    </div>
    <p class="feedback-toast" aria-live="polite"></p>
  </div>
</article>

<script>
  import { loadFeedback, saveFeedback, type StoredFeedback } from '../lib/feedback-client';

  document.querySelectorAll('img[data-fallback]').forEach((img) => {
    img.addEventListener('error', () => {
      const div = document.createElement('div');
      div.className = 'article-img placeholder';
      div.textContent = '画像を読み込めませんでした';
      img.replaceWith(div);
    });
  });

  document.querySelectorAll('.feedback').forEach((group) => {
    const el = group as HTMLElement;
    const id = el.dataset.feedbackId!;
    const stored = loadFeedback();
    if (stored[id]) {
      const btn = el.querySelector(`[data-v="${stored[id].verdict}"]`);
      btn?.classList.add(stored[id].verdict === 'good' ? 'is-good' : 'is-bad');
    }

    el.querySelectorAll('button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const v = (btn as HTMLButtonElement).dataset.v as StoredFeedback['verdict'];
        const all = loadFeedback();
        all[id] = {
          verdict: v,
          url: el.dataset.url!,
          sourceId: el.dataset.sourceId!,
          date: new Date().toISOString().slice(0, 10),
        };
        saveFeedback(all);
        el.querySelectorAll('button').forEach((b) => b.classList.remove('is-good', 'is-bad'));
        btn.classList.add(v === 'good' ? 'is-good' : 'is-bad');
        const toast = el.parentElement?.querySelector('.feedback-toast');
        if (toast) {
          toast.textContent =
            '記録しました。フッターの「フィードバックをエクスポート」から JSONL をダウンロードし、data/feedback.jsonl に反映できます。';
        }
      });
    });
  });
</script>
