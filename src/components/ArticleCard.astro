---
import ArticleMedia from './ArticleMedia.astro';

interface ArticleVideo {
  provider: 'youtube' | 'vimeo' | 'html5';
  embedUrl: string;
}

interface Article {
  title: string;
  summary: string;
  source: string;
  sourceId: string;
  url: string;
  image?: string;
  images?: string[];
  video?: ArticleVideo;
}

import { t, type Locale } from '../i18n/ui';

interface Props {
  article: Article;
  index: number;
  digestSlug: string;
  locale: Locale;
}

const { article, index, locale } = Astro.props;
const num = String(index + 1).padStart(2, '0');
const mediaImages =
  article.images && article.images.length > 0
    ? article.images
    : article.image
      ? [article.image]
      : [];
---

<article class="article-card" data-article-url={article.url}>
  <ArticleMedia
    images={mediaImages}
    video={article.video}
    sourceId={article.sourceId}
    priority={index === 0}
    locale={locale}
  />
  <div class="article-body">
    <div class="article-num">{num}</div>
    <h2>{article.title}</h2>
    <p class="summary">{article.summary}</p>
    <p class="source-line">
      {t(locale, 'sourceLabel')}: <a href={article.url} target="_blank" rel="noopener noreferrer">{article.source}</a>
    </p>
    <div
      class="feedback"
      data-url={article.url}
      data-source-id={article.sourceId}
      data-msg-unavailable={t(locale, 'feedbackUnavailable')}
      data-msg-cleared={t(locale, 'feedbackCleared')}
      data-msg-saved={t(locale, 'feedbackSaved')}
      data-msg-failed={t(locale, 'feedbackFailed')}
    >
      <button type="button" class="feedback-btn" data-v="good" aria-pressed="false">
        <span class="feedback-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.96 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z" />
          </svg>
        </span>
        <span class="feedback-label">{locale === 'en' ? t(locale, 'feedbackGood') : 'Good'}</span>
      </button>
      <button type="button" class="feedback-btn" data-v="bad" aria-pressed="false">
        <span class="feedback-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M15 3H6c-.83 0-1.54.5-1.84 1.22l-3.02 7.05c-.09.23-.14.47-.14.73v2c0 1.1.9 2 2 2h6.31l-.95 4.57-.03.32c0 .41.17.79.44 1.06L9.83 23 16.41 16.41c.37-.37.59-.86.59-1.41V5c0-1.1-.9-2-2-2zm4 0v12h4V3h-4z" />
          </svg>
        </span>
        <span class="feedback-label">{locale === 'en' ? t(locale, 'feedbackBad') : 'Bad'}</span>
      </button>
    </div>
    <p class="feedback-toast" aria-live="polite"></p>
  </div>
</article>

<script>
  import {
    deleteVote,
    fetchMyVotes,
    getSupabaseBrowser,
    upsertVote,
    type Verdict,
  } from '../lib/feedback-client';

  function setPressed(group: HTMLElement, verdict: Verdict | null) {
    group.querySelectorAll('.feedback-btn').forEach((btn) => {
      const v = (btn as HTMLButtonElement).dataset.v;
      const active = verdict !== null && v === verdict;
      btn.classList.toggle('is-good', active && v === 'good');
      btn.classList.toggle('is-bad', active && v === 'bad');
      btn.classList.toggle('is-pressed', active);
      btn.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  }

  function flash(btn: HTMLButtonElement) {
    btn.classList.remove('feedback-pop');
    void btn.offsetWidth;
    btn.classList.add('feedback-pop');
  }

  async function initFeedback() {
    const groups = [...document.querySelectorAll<HTMLElement>('.feedback')];
    if (groups.length === 0) return;

    const supabase = getSupabaseBrowser();
    const urls = groups.map((g) => g.dataset.url!).filter(Boolean);

    let myVotes: Record<string, Verdict> = {};
    if (supabase) {
      try {
        myVotes = await fetchMyVotes(urls);
      } catch {
        /* show buttons without state */
      }
    }

    groups.forEach((group) => {
      const url = group.dataset.url!;
      setPressed(group, myVotes[url] ?? null);

      group.querySelectorAll<HTMLButtonElement>('.feedback-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const v = btn.dataset.v as Verdict;
          const toast = group.parentElement?.querySelector('.feedback-toast');
          const current = myVotes[url] ?? null;

          if (!supabase) {
            if (toast) toast.textContent = group.dataset.msgUnavailable ?? '';
            return;
          }

          try {
            if (current === v) {
              await deleteVote(url);
              delete myVotes[url];
              setPressed(group, null);
              if (toast) toast.textContent = group.dataset.msgCleared ?? '';
            } else {
              await upsertVote({
                url,
                sourceId: group.dataset.sourceId!,
                verdict: v,
              });
              myVotes[url] = v;
              setPressed(group, v);
              flash(btn);
              if (toast) toast.textContent = group.dataset.msgSaved ?? '';
            }
          } catch (err) {
            if (toast) {
              toast.textContent =
                err instanceof Error ? err.message : (group.dataset.msgFailed ?? '');
            }
          }
        });
      });
    });
  }

  initFeedback();
  document.addEventListener('astro:page-load', initFeedback);
</script>
