---
import { t, type Locale } from '../i18n/ui';

interface ArticleVideo {
  provider: 'youtube' | 'vimeo' | 'html5';
  embedUrl: string;
}

interface Props {
  images: string[];
  video?: ArticleVideo;
  sourceId?: string;
  priority?: boolean;
  locale?: Locale;
}

const locale = (Astro.props.locale ?? Astro.currentLocale ?? 'ja') as Locale;
const { images, video, priority = false } = Astro.props;
const videoLabel = t(locale, 'articleVideoLabel');
const mediaNoImage = t(locale, 'mediaNoImage');
const mediaPrev = t(locale, 'mediaPrev');
const mediaNext = t(locale, 'mediaNext');
const mediaLoadFailed = t(locale, 'mediaLoadFailed');
const slides = [...images];
const slideCount = slides.length + (video ? 1 : 0);
const hasCarousel = slideCount > 1;
const uid = `media-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class={`article-media${hasCarousel ? ' has-carousel' : ''}`}
  data-media-id={uid}
  data-locale={locale}
  data-load-failed={mediaLoadFailed}
  tabindex={hasCarousel ? 0 : undefined}
>
  <div class="article-media-viewport">
    {
      slides.map((src, i) => (
        <figure class="article-media-slide" data-slide-index={i} hidden={i !== 0 ? true : undefined}>
          <img
            class="article-img"
            src={src}
            alt=""
            loading={priority && i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={priority && i === 0 ? 'high' : undefined}
            data-fallback
          />
        </figure>
      ))
    }
    {
      video ? (
        <figure
          class="article-media-slide article-media-video"
          data-slide-index={slides.length}
          hidden={slides.length > 0 ? true : undefined}
        >
          {
            video.provider === 'html5' ? (
              <video class="article-native-video" controls playsinline preload="metadata">
                <source src={video.embedUrl} type="video/mp4" />
                <a href={video.embedUrl} target="_blank" rel="noopener noreferrer">
                  {videoLabel}
                </a>
              </video>
            ) : (
              <iframe
                src={video.embedUrl}
                title={videoLabel}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            )
          }
        </figure>
      ) : null
    }
    {
      !slides.length && !video ? (
        <div class="article-img placeholder">{mediaNoImage}</div>
      ) : null
    }
  </div>
  {
    hasCarousel ? (
      <>
        <button type="button" class="article-media-nav prev" aria-label={mediaPrev} data-dir="-1">
          <span class="article-media-nav-icon" aria-hidden="true">‹</span>
        </button>
        <button type="button" class="article-media-nav next" aria-label={mediaNext} data-dir="1">
          <span class="article-media-nav-icon" aria-hidden="true">›</span>
        </button>
        <span class="article-media-counter" aria-live="polite">
          1 / {slideCount}
        </span>
      </>
    ) : null
  }
</div>

<script>
  function initMediaCarousels() {
    document.querySelectorAll('.article-media.has-carousel').forEach((root) => {
      const slides = [...root.querySelectorAll('.article-media-slide')];
      if (slides.length <= 1) return;

      let index = slides.findIndex((s) => !s.hasAttribute('hidden'));
      if (index < 0) index = 0;

      const counter = root.querySelector('.article-media-counter');
      const loadFailed =
        (root as HTMLElement).dataset.loadFailed ?? 'Could not load image';

      const show = (i: number) => {
        index = (i + slides.length) % slides.length;
        slides.forEach((s, j) => {
          if (j === index) s.removeAttribute('hidden');
          else s.setAttribute('hidden', '');
        });
        if (counter) counter.textContent = `${index + 1} / ${slides.length}`;
      };

      root.querySelectorAll('.article-media-nav').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number((btn as HTMLButtonElement).dataset.dir ?? 1);
          show(index + dir);
        });
      });

      root.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
        if (!root.contains(document.activeElement)) return;
        e.preventDefault();
        const dir = e.key === 'ArrowLeft' ? -1 : 1;
        show(index + dir);
      });
    });

    document.querySelectorAll('img[data-fallback]').forEach((img) => {
      img.addEventListener('error', () => {
        const fig = img.closest('.article-media-slide');
        const root = img.closest('.article-media') as HTMLElement | null;
        const msg = root?.dataset.loadFailed ?? 'Could not load image';
        if (fig) {
          fig.innerHTML = `<div class="article-img placeholder">${msg}</div>`;
        }
      });
    });
  }

  initMediaCarousels();
  document.addEventListener('astro:page-load', initMediaCarousels);
</script>
