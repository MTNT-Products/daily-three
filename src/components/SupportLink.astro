---
import { getSupportUrl } from '../lib/support';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const supportUrl = getSupportUrl();
---

{
  supportUrl && (
    <a
      href={supportUrl}
      class={className}
      target="_blank"
      rel="noopener noreferrer"
    >
      <slot>サイト運営を支援する</slot>
    </a>
  )
}
