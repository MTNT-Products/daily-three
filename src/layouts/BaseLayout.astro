---
import '../styles/global.css';
import { sitePath } from '../lib/site-url';
import SupportLink from '../components/SupportLink.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daily Three: Auto & Product Design — 毎日3件のデザインニュース' } = Astro.props;
const homePath = sitePath('');
const archivePath = sitePath('archive/');
const aboutPath = sitePath('about/');
const privacyPath = sitePath('privacy/');
const disclaimerPath = sitePath('disclaimer/');
const pathname = Astro.url.pathname;
const isHome =
  pathname === homePath ||
  pathname === homePath.replace(/\/$/, '') ||
  pathname.endsWith('/daily-three/') ||
  pathname.endsWith('/daily-three');
const isSubpage =
  pathname.includes('/archive') ||
  pathname.includes('/about') ||
  pathname.includes('/digest') ||
  pathname.includes('/privacy') ||
  pathname.includes('/disclaimer');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={sitePath('favicon.svg')} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={homePath} style="text-decoration: none; color: inherit">
        <div class="brand">Daily Three</div>
        <div class="tagline">Auto &amp; Product Design</div>
      </a>
      <nav class="site-nav" aria-label="メイン">
        <a href={homePath} aria-current={isSubpage ? undefined : 'page'}>Home</a>
        <a href={archivePath} aria-current={pathname.includes('/archive') ? 'page' : undefined}>Archive</a>
        <a href={aboutPath} aria-current={pathname.includes('/about') ? 'page' : undefined}>About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Daily Three — personal curation for industrial &amp; product design</p>
      <nav class="site-footer-nav" aria-label="法務・ポリシー・支援">
        <a href={privacyPath}>プライバシーポリシー</a>
        <span aria-hidden="true"> · </span>
        <a href={disclaimerPath}>免責事項</a>
        <span class="site-footer-support">
          <span aria-hidden="true"> · </span>
          <SupportLink />
        </span>
      </nav>
    </footer>
  </body>
</html>
