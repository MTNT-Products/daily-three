---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const digests = (await getCollection('digest')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = digests[0];
---

<BaseLayout title="Daily Three — Auto & Product Design">
  <div class="home-hero">
    <h1>毎日、デザインの注目3件</h1>
    <p>カーデザインを中心に、プロダクトデザインのニュースを日本語で。</p>
  </div>
  {
    latest ? (
      <a class="home-latest" href={`${import.meta.env.BASE_URL}digest/${latest.id}/`}>
        最新: {latest.data.title} →
      </a>
    ) : (
      <p>まだダイジェストがありません。</p>
    )
  }
</BaseLayout>
