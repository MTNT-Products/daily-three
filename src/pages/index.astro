---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { sitePath } from '../lib/site-url';
import { getCollection } from 'astro:content';

const digests = (await getCollection('digest')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = digests[0];
---

<BaseLayout title="Daily Three — Auto & Product Design">
  <div class="home-hero">
    <h1>毎日、デザインの注目3件</h1>
    <p>カーデザインを中心に、プロダクトデザインのニュースを日本語で。</p>
  </div>
  {
    latest ? (
      <>
        <section class="home-preview" aria-labelledby="home-preview-title">
          <div class="home-preview-head">
            <h2 id="home-preview-title">今日の3件 — {latest.data.title}</h2>
            <a class="home-preview-link" href={sitePath(`digest/${latest.id}/`)}>
              全文を読む →
            </a>
          </div>
          <p class="digest-lead">{latest.data.lead}</p>
          {latest.data.articles.map((article, index) => (
            <ArticleCard article={article} index={index} digestSlug={latest.id} />
          ))}
        </section>
      </>
    ) : (
      <p>まだダイジェストがありません。</p>
    )
  }
</BaseLayout>
