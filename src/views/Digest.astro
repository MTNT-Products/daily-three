---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';
import { digestSlugFromEntryId } from '../lib/digest';
import type { Locale } from '../i18n/ui';

interface Props {
  entry: Awaited<ReturnType<typeof getCollection<'digest'>>>[number];
}

const { entry } = Astro.props;
const locale = Astro.currentLocale as Locale;
const slug = digestSlugFromEntryId(entry.id);
const { Content } = await render(entry);

const all = await getCollection('digest');
const altLocale: Locale = locale === 'ja' ? 'en' : 'ja';
const hasAlt = all.some((e) => e.id === `${altLocale}/${slug}`);
const alternateLocales = hasAlt ? (['ja', 'en'] as Locale[]) : [locale];
---

<BaseLayout
  title={`${entry.data.title} — Daily Three`}
  description={entry.data.lead}
  path={`digest/${slug}/`}
  alternateLocales={alternateLocales}
>
  <p class="digest-meta">{entry.data.title}</p>
  <p class="digest-lead">{entry.data.lead}</p>
  {entry.data.articles.map((article, index) => (
    <ArticleCard article={article} index={index} digestSlug={slug} locale={locale} />
  ))}
  <Content />
</BaseLayout>
